FROM node:20.19-alpine AS build
WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY . .
ARG VITE_API_BASE_URL=http://backend:8000
ARG VITE_ENABLE_REGISTER=false
RUN VITE_API_BASE_URL=${VITE_API_BASE_URL} VITE_ENABLE_REGISTER=${VITE_ENABLE_REGISTER} npm run build

FROM nginx:alpine
COPY --from=build /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
