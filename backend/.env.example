# Backend env
# For local dev without Docker/Postgres:
# DATABASE_URL=sqlite+aiosqlite:///./apptracker.db

# For Postgres (Docker compose / deployed):
DATABASE_URL=postgresql+asyncpg://app:app@localhost:5432/apptracker
SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_STRING
CORS_ORIGINS=http://localhost:5173

# Demo mode options
ENABLE_REGISTRATION=false
DEMO_EMAIL=demo@apptrack.dev
DEMO_PASSWORD=ChangeMeDemo123!
